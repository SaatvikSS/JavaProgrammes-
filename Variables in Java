public class variables {
    public static void main(String[] args) {
        int a = 10;
        int b = 5;
        int sum = a+b;
        System.out.println(sum);

        int diff = b-a;
        System.out.println(diff);

        int prod = b*a;
        System.out.println(prod);

        int divd = a/b;
        System.out.println(divd);

        int ans = (a*b)/(a-b);
        System.out.println(ans);
        
    }
}
